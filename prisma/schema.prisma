generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  Confession
  Regret
  Secret
  Advice
}

enum ReactionType {
  SUPPORT
  RELATE
  HUG
  STAY_STRONG
  PROUD_OF_YOU
  THATS_TOUGH
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  createdAt DateTime @default(now())
  confessions Confession[]
}

model Confession {
  id        String   @id @default(cuid())
  content   String
  category  Category @default(Confession)
  createdAt DateTime @default(now())

  reactions Reaction[]
  user      User?      @relation(fields: [userId], references: [id])
  userId    String?
}

model Reaction {
  id           String     @id @default(cuid())
  confessionId String
  confession   Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)

  userId String
  type   ReactionType

  @@unique([confessionId, userId])
}
